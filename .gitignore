# ============================================================
# LocalBro — .gitignore
# ============================================================

# ---------- JavaScript / Node ----------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
node_modules
dist
dist-ssr
*.local

# ---------- Environment & Secrets ----------
# .env files may contain VITE_xxx vars used to inject tokens at build
# time. NEVER commit these.
.env
.env.*
!.env.example        # keep the example template (no real secrets)

# ---------- Rust / Tauri ----------
# Compilation cache — up to several GB, never commit
src-tauri/target/
# Mobile platform scaffolding generated by `tauri android / ios init`
src-tauri/gen/
# WiX tooling downloaded at build time (Windows installer)
WixTools/
# Signing certificates and keys
*.pem
*.p12
*.pfx
*.cer
*.key
# Tauri update signatures generated per-release
*.sig

# ---------- macOS ----------
.DS_Store
**/.DS_Store

# ---------- Editor ----------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------- OS / Build artifacts ----------
Thumbs.db
ehthumbs.db
Desktop.ini
*.tmp
*.bak

# ---------- Release bundles (local build output) ----------
# The Tauri bundler writes installers here; these are published via
# GitHub Releases, not committed to the repository.
src-tauri/target/release/bundle/
